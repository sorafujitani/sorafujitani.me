---
import { getEntry, render } from 'astro:content';
import BlogLayout from '@layouts/BlogLayout.astro';

const about = await getEntry('about', 'index');
const { Content } = await render(about);
---

<BlogLayout title="About" description="Sora Fujitaniについて">
  <div class="about-container">
    <section class="profile-section">
      <img src="/profile.png" alt="Sora Fujitani" class="profile-image" />
      <h1>Sora Fujitani</h1>
    </section>

    <section class="about-content">
      <Content />
    </section>
  </div>
</BlogLayout>

<style>
  .about-container {
    max-width: 680px;
  }

  .profile-section {
    text-align: center;
    margin-bottom: 48px;
  }

  .profile-image {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 24px;
  }

  .profile-section h1 {
    font-size: 36px;
    font-weight: 700;
    margin: 0;
    color: var(--color-heading);
  }

  .about-content {
    font-size: 18px;
    line-height: 1.8;
    color: var(--color-text);
  }

  .about-content :global(h2) {
    font-size: 24px;
    font-weight: 600;
    margin: 48px 0 20px 0;
    color: var(--color-heading);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 8px;
  }

  .about-content :global(h3) {
    font-size: 20px;
    font-weight: 600;
    margin: 32px 0 16px 0;
    color: var(--color-heading);
  }

  .about-content :global(p) {
    margin: 0 0 24px 0;
  }

  .about-content :global(ul),
  .about-content :global(ol) {
    margin: 0 0 24px 0;
    padding-left: 24px;
  }

  .about-content :global(li) {
    margin: 8px 0;
  }

  .about-content :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .about-content :global(a:hover) {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }

  /* Link Card */
  .about-content :global(.link-card) {
    display: block;
    background: var(--color-tag-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none !important;
    margin: 24px 0;
    transition: border-color 0.2s ease;
  }

  .about-content :global(.link-card:hover) {
    border-color: var(--color-accent);
  }

  .about-content :global(.link-card-content) {
    display: flex;
    gap: 20px;
    padding: 20px;
  }

  .about-content :global(.link-card-text) {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .about-content :global(.link-card-title) {
    font-size: 17px;
    font-weight: 700;
    color: var(--color-heading) !important;
    margin: 0 0 10px 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    line-height: 1.4;
    text-decoration: none !important;
  }

  .about-content :global(.link-card-description) {
    font-size: 14px;
    color: var(--color-text-muted) !important;
    margin: 0 0 12px 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    line-height: 1.6;
    text-decoration: none !important;
  }

  .about-content :global(.link-card-url) {
    font-size: 13px;
    color: var(--color-text-muted) !important;
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
    text-decoration: none !important;
  }

  .about-content :global(.link-card-image) {
    width: 140px;
    height: 140px;
    flex-shrink: 0;
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-tag-bg);
  }

  .about-content :global(.link-card-image img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .about-content :global(.link-card-content) {
      flex-direction: column-reverse;
      padding: 16px;
    }

    .about-content :global(.link-card-image) {
      width: 100%;
      height: 200px;
    }
  }

</style>
