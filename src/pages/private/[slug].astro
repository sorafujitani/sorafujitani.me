---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BlogLayout from '@layouts/BlogLayout.astro';
import TableOfContents from '../blog/_components/TableOfContents.astro';
import { formatDate } from '@lib/date';
import { SITE_URL } from '@lib/constants';

export async function getStaticPaths() {
  const posts = await getCollection('private');
  return posts
    .filter(post => !post.data.draft)
    .map(post => ({
      params: { slug: post.id },
      props: { post },
    }));
}

interface Props {
  post: CollectionEntry<'private'>;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const siteUrl = Astro.site || SITE_URL;
const postUrl = new URL(`/private/${post.id}`, siteUrl).toString();

const formattedDate = formatDate(post.data.pubDate);
const formattedUpdatedDate = post.data.updatedDate ? formatDate(post.data.updatedDate) : null;
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  image={`/og/${post.id}.png`}
  noindex
>
  <article class="blog-post">
    <header class="post-header">
      <div class="unlisted-badge" aria-label="Unlisted page">Unlisted · 一覧非掲載</div>
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
        {formattedUpdatedDate && (
          <>
            <span class="separator">•</span>
            <span class="updated">更新: {formattedUpdatedDate}</span>
          </>
        )}
        <span class="separator">•</span>
        <span class="author">{post.data.author}</span>
      </div>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="tags">
          {post.data.tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>
    <TableOfContents headings={headings} />
    <div class="post-content">
      <Content />
    </div>

    <footer class="post-footer">
      <div class="share-buttons">
        <span class="share-label">Share link:</span>
        <button
          class="share-button share-copy"
          aria-label="Copy link"
          data-url={postUrl}
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
        </button>
      </div>
    </footer>
  </article>
</BlogLayout>

<script>
  if (document.querySelector('.twitter-tweet') && !document.getElementById('twitter-wjs')) {
    const script = document.createElement('script');
    script.id = 'twitter-wjs';
    script.src = 'https://platform.twitter.com/widgets.js';
    script.async = true;
    document.head.appendChild(script);
  }

  document.querySelectorAll('.share-copy').forEach(button => {
    button.addEventListener('click', async () => {
      const url = button.getAttribute('data-url');
      if (url) {
        await navigator.clipboard.writeText(url);
        button.classList.add('copied');
        setTimeout(() => button.classList.remove('copied'), 2000);
      }
    });
  });
</script>

<style>
  .blog-post {
    max-width: 680px;
  }

  .post-header {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--color-border);
  }

  .unlisted-badge {
    display: inline-block;
    padding: 4px 10px;
    margin-bottom: 16px;
    background: rgba(255, 200, 0, 0.12);
    border: 1px solid rgba(255, 200, 0, 0.35);
    border-radius: 4px;
    color: #ffc800;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  h1 {
    font-size: 36px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 16px 0;
    color: var(--color-heading);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    color: var(--color-text-muted);
  }

  .separator {
    color: #6b7280;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .tag {
    display: inline-block;
    padding: 4px 12px;
    background: var(--color-tag-bg);
    color: var(--color-text-secondary);
    font-size: 14px;
    border-radius: 16px;
  }

  .post-content {
    font-size: 18px;
    line-height: 1.8;
    color: var(--color-text);
  }

  .post-content :global(h1) {
    font-size: 32px;
    font-weight: 700;
    margin: 48px 0 24px;
    line-height: 1.2;
  }

  .post-content :global(h2) {
    font-size: 28px;
    font-weight: 700;
    margin: 40px 0 20px;
    line-height: 1.3;
  }

  .post-content :global(h3) {
    font-size: 24px;
    font-weight: 600;
    margin: 32px 0 16px;
    line-height: 1.3;
  }

  .post-content :global(p) {
    margin: 0 0 24px 0;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 0 0 24px 0;
    padding-left: 24px;
  }

  .post-content :global(li) {
    margin: 8px 0;
  }

  .post-content :global(code) {
    background: rgba(0, 216, 255, 0.1);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
    color: #00d8ff;
  }

  .post-content :global(pre) {
    background: var(--color-code-bg);
    color: var(--color-code-text);
    padding: 20px;
    border-radius: 8px;
    overflow-x: auto;
    margin: 0 0 24px 0;
    position: relative;
  }

  .post-content :global(.github-embed) {
    margin: 0 0 24px 0;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .post-content :global(.github-embed-header) {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: #1c2128;
    border-bottom: 1px solid var(--color-border);
  }

  .post-content :global(.github-embed-icon) {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .post-content :global(.github-embed-meta) {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .post-content :global(.github-embed-link) {
    color: var(--color-accent) !important;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none !important;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .post-content :global(.github-embed-link:hover) {
    text-decoration: underline !important;
  }

  .post-content :global(.github-embed-line-info) {
    color: var(--color-text-muted);
    font-size: 12px;
  }

  .post-content :global(.tweet-embed) {
    display: flex;
    justify-content: center;
    margin: 24px 0;
  }

  .post-content :global(.tweet-embed .twitter-tweet) {
    margin: 0 !important;
  }

  .post-content :global(.link-card) {
    display: block;
    background: var(--color-tag-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none !important;
    margin: 24px 0;
    transition: border-color 0.2s ease;
  }

  .post-content :global(.link-card:hover) {
    border-color: var(--color-accent);
  }

  .post-content :global(.link-card-content) {
    display: flex;
    gap: 20px;
    padding: 20px;
  }

  .post-content :global(.link-card-text) {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .post-content :global(.link-card-title) {
    font-size: 17px;
    font-weight: 700;
    color: var(--color-heading) !important;
    margin: 0 0 10px 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    line-height: 1.4;
    text-decoration: none !important;
  }

  .post-content :global(.link-card-description) {
    font-size: 14px;
    color: var(--color-text-muted) !important;
    margin: 0 0 12px 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    line-height: 1.6;
    text-decoration: none !important;
  }

  .post-content :global(.link-card-url) {
    font-size: 13px;
    color: var(--color-text-muted) !important;
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
    text-decoration: none !important;
  }

  .post-content :global(.link-card-image) {
    width: 140px;
    height: 140px;
    flex-shrink: 0;
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-tag-bg);
  }

  .post-content :global(.link-card-image img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-content :global(.github-embed pre) {
    margin: 0 !important;
    border-radius: 0 !important;
    border: none !important;
    white-space: pre !important;
    word-wrap: normal !important;
    overflow-x: auto;
  }

  .post-content :global(pre[data-filename]) {
    padding-top: 40px;
  }

  .post-content :global(pre[data-filename])::before {
    content: attr(data-filename);
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: 8px 16px;
    background: #1c2128;
    color: #8b949e;
    font-size: 13px;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
    border-radius: 8px 8px 0 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-content :global(pre code) {
    background: transparent;
    padding: 0;
    font-size: 14px;
    line-height: 1.6;
    border: none;
    color: inherit;
  }

  .post-content :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .post-content :global(a:hover) {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid var(--color-border);
    padding-left: 20px;
    margin: 24px 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 24px 0;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 48px 0;
  }

  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-size: 15px;
    overflow-x: auto;
    display: block;
  }

  .post-content :global(th),
  .post-content :global(td) {
    padding: 12px 16px;
    text-align: left;
    border: 1px solid var(--color-border);
  }

  .post-content :global(th) {
    background: var(--color-tag-bg);
    font-weight: 600;
    color: var(--color-heading);
    white-space: nowrap;
  }

  .post-content :global(td) {
    background: var(--color-code-bg);
  }

  .post-content :global(tr:hover td) {
    background: var(--color-tag-bg);
  }

  .post-content :global(td code) {
    font-size: 0.9em;
  }

  .post-footer {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }

  .share-buttons {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .share-label {
    font-size: 14px;
    color: var(--color-text-muted);
  }

  .share-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--color-tag-bg);
    color: var(--color-text-secondary);
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .share-button:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .share-copy.copied {
    background: #22c55e;
    color: white;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 28px;
    }

    .post-content {
      font-size: 16px;
    }

    .post-content :global(h1) {
      font-size: 26px;
    }

    .post-content :global(h2) {
      font-size: 22px;
    }

    .post-content :global(h3) {
      font-size: 20px;
    }

    .post-content :global(.link-card-content) {
      flex-direction: column-reverse;
      padding: 16px;
    }

    .post-content :global(.link-card-image) {
      width: 100%;
      height: 200px;
    }

    .post-content :global(.link-card-title) {
      font-size: 16px;
    }

    .post-content :global(.link-card-description) {
      font-size: 13px;
    }
  }
</style>
